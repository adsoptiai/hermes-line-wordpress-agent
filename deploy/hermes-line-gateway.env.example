# Copy to /etc/hermes-line-wordpress-agent/line-gateway.env and chmod 600.

LINE_CHANNEL_SECRET=""
LINE_CHANNEL_ACCESS_TOKEN=""

# Comma-separated allowlists. Leave empty only for a private test channel.
LINE_ALLOWED_USER_IDS=""
LINE_ALLOWED_GROUP_IDS=""
LINE_ALLOWED_ROOM_IDS=""
LINE_REQUIRE_ALLOWLIST=true

# ack_then_push replies immediately with LINE replyToken, then pushes the final result.
# reply waits for Hermes and sends the final result with replyToken.
LINE_REPLY_MODE=ack_then_push
LINE_ACK_MESSAGE="Received. Hermes is working on it."
LINE_UNAUTHORIZED_MESSAGE="This LINE account is not authorized."
LINE_LOADING_ENABLED=true
LINE_LOADING_SECONDS=60
LINE_LOADING_SKIP_ACK=true
LINE_GATEWAY_HOST=127.0.0.1
LINE_GATEWAY_PORT=8787

# Hermes Agent CLI settings.
HERMES_BIN=/home/ubuntu/.local/bin/hermes
HERMES_MODEL=kimi-k2.6:cloud
HERMES_PROVIDER=custom
HERMES_TOOLSETS=wordpress
HERMES_WORKDIR=/home/ubuntu
HERMES_TIMEOUT_SECONDS=300
HERMES_EXTRA_ARGS=""
