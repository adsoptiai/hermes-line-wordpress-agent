# Copy to /etc/hermes-line-wordpress-agent/env and chmod 600.

WORDPRESS_BASE_URL=https://cms.example.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=""
WORDPRESS_BRIDGE_TOKEN=""

WP_DEFAULT_STATUS=draft
WP_DEFAULT_AUTHOR=

SITE_PROFILE_PATH=/etc/hermes-line-wordpress-agent/site.profile.yaml
POLICY_PATH=/etc/hermes-line-wordpress-agent/policy.yaml
