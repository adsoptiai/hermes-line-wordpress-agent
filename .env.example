# WordPress REST base, without the trailing /wp-json.
# Example: https://cms.example.com
WORDPRESS_BASE_URL=

# WordPress Application Password credentials.
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# Optional companion plugin shared token.
# Required for plugin-only endpoints such as SEO meta updates.
WORDPRESS_BRIDGE_TOKEN=

# Default behavior for generated content.
WP_DEFAULT_STATUS=draft
WP_DEFAULT_AUTHOR=

# Local paths.
SITE_PROFILE_PATH=config/site.profile.example.yaml
POLICY_PATH=config/policy.example.yaml

# LINE gateway credentials. Keep real values out of Git.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ALLOWED_USER_IDS=
LINE_ALLOWED_GROUP_IDS=
LINE_ALLOWED_ROOM_IDS=
LINE_REQUIRE_ALLOWLIST=true
LINE_REPLY_MODE=ack_then_push

# Hermes CLI settings used by the LINE gateway.
HERMES_BIN=hermes
HERMES_MODEL=
HERMES_PROVIDER=
HERMES_TOOLSETS=wordpress
HERMES_WORKDIR=.
HERMES_TIMEOUT_SECONDS=300
